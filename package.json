{
  "name": "hyperauth",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build:css && bun build --compile ./src/server.tsx",
    "build:css": "mkdir -p public/styles && tailwindcss -i src/styles/tailwind.css -o public/styles/tailwind.css --minify",
    "build:css:watch": "mkdir -p public/styles && tailwindcss -i src/styles/tailwind.css -o public/styles/tailwind.css --watch",
    "dev": "bun run build:css && concurrently -k \"bun run build:css:watch\" \"bun run server\"",
    "server": "bun --watch src/server.tsx",
    "setup": "./setup.sh",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run format:check && bun run lint && bun run test",
    "test": "bun test src tests",
    "test:coverage": "bun test --coverage src tests",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.11.4",
    "jose": "^6.1.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.0.9",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "bun-types": "^1.3.6",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.2",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "husky": "^9.1.7",
    "prettier": "3.8.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3"
  },
  "module": "src/server.tsx",
  "husky": {
    "hooks": {
      "pre-commit": "bun run check"
    }
  },
  "bun": {
    "test": {
      "coverage": true,
      "coverageThreshold": {
        "global": {
          "lines": 80,
          "functions": 80,
          "branches": 70,
          "statements": 80
        }
      },
      "coverageIgnorePatterns": [
        "assets/**",
        "__tests__/**",
        "node_modules/**"
      ]
    }
  }
}
