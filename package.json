{
  "name": "hyperauth",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build:css && bun build --compile ./src/server.tsx",
    "build:css": "mkdir -p public/styles && ./node_modules/.bin/tailwindcss -i src/styles/tailwind.css -o public/styles/tailwind.css --minify",
    "build:css:watch": "mkdir -p public/styles && ./node_modules/.bin/tailwindcss -i src/styles/tailwind.css -o public/styles/tailwind.css --watch",
    "dev": "bun run build:css && concurrently \"bun run build:css:watch\" \"bun --watch src/server.tsx\" -k",
    "format:check": "bun x prettier@3.5.1 --check \"src/**/*.{ts,tsx}\"",
    "lint": "bun x eslint \"src/**/*.{ts,tsx}\"",
    "precommit": "bun run typecheck && bun run format:check && bun run lint && bun run test:unit",
    "prepare": "husky",
    "prettier": "bun x prettier@3.5.1 --write \"src/**/*.{ts,tsx}\"",
    "server": "bun --watch src/server.tsx",
    "setup": "./setup.sh",
    "test:unit": "bun test src tests",
    "test:coverage": "bun test --coverage",
    "typecheck": "bun x tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/zod-validator": "^0.7.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.11.4",
    "jose": "^6.1.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "bun-types": "^1.3.6",
    "concurrently": "^9.1.2",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "prettier": "3.8.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3"
  },
  "module": "src/server.tsx",
  "husky": {
    "hooks": {
      "pre-commit": "bun run precommit"
    }
  },
  "bun": {
    "test": {
      "coverage": true,
      "coverageThreshold": {
        "global": {
          "lines": 80,
          "functions": 80,
          "branches": 70,
          "statements": 80
        }
      },
      "coverageIgnorePatterns": [
        "assets/**",
        "__tests__/**",
        "node_modules/**"
      ]
    }
  }
}
