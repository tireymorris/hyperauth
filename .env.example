# Application
APP_NAME=HyperAuth
NODE_ENV=development
PORT=3000
HOST=http://localhost:3000
SKIP_AUTH=false

# Authentication (SECRET_KEY must be at least 32 characters)
SECRET_KEY=your_secret_key_must_be_at_least_32_characters_long

# Email (Resend)
EMAIL_FROM="auth@yourdomain.com"
RESEND_API_KEY=re_your_resend_api_key
